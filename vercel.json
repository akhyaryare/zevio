{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "app.html",   "use": "@vercel/static" },
    { "src": "me.html",    "use": "@vercel/static" },
    { "src": "hub.html",   "use": "@vercel/static" },
    { "src": "smart.html", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "hub.zevio.co.uk" }],   "destination": "/hub.html" },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "smart.zevio.co.uk" }], "destination": "/smart.html" },
    { "source": "/me",       "destination": "/me.html" },
    { "source": "/app",      "destination": "/app.html" },
    { "source": "/app/(.*)", "destination": "/app.html" },
    { "source": "/hub",      "destination": "/hub.html" },
    { "source": "/smart",    "destination": "/smart.html" },
    { "source": "/((?!index\\.html$).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
